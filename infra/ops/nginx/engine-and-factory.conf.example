# Example reverse proxy for engine + private factory UI.
# TLS hostnames are set for the current production baseline.

server {
  listen 443 ssl http2;
  server_name aiblogs.earningsites.net;

  ssl_certificate     /etc/letsencrypt/live/aiblogs.earningsites.net/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/aiblogs.earningsites.net/privkey.pem;

  client_max_body_size 10m;

  location / {
    proxy_pass http://127.0.0.1:8787;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  # Keep Factory UI off the public internet.
  # Preferred access path:
  # 1. join the admin tailnet
  # 2. open an SSH tunnel to 127.0.0.1:8787
  # 3. browse http://127.0.0.1:<local-port>/ops/factory
  location /ops/factory {
    deny all;
  }
}

server {
  listen 443 ssl http2;
  server_name n8n.earningsites.net;

  # Certbot currently issues one SAN certificate named after the first domain.
  ssl_certificate     /etc/letsencrypt/live/aiblogs.earningsites.net/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/aiblogs.earningsites.net/privkey.pem;

  location / {
    proxy_pass http://127.0.0.1:5678;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
  }
}
