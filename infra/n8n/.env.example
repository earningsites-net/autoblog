# n8n host
N8N_HOST=n8n.earningsites.net
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.earningsites.net/
N8N_EDITOR_BASE_URL=https://n8n.earningsites.net/
N8N_API_BASE_URL=https://n8n.earningsites.net
N8N_API_KEY=
N8N_ENCRYPTION_KEY=replace-with-strong-random-value
GENERIC_TIMEZONE=Europe/Rome
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
NODE_FUNCTION_ALLOW_EXTERNAL=node-fetch
NODE_FUNCTION_ALLOW_BUILTIN=buffer

# Auth
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace-me

# Postgres
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-me

# Site context (optional fallback for legacy single-site runs)
SITE_SLUG=
# NOTE: strict per-site mode
# n8n resolves Sanity connection at runtime from:
# GET {CONTENT_ENGINE_URL}/api/internal/sites/:siteSlug/sanity-connection
# So SANITY_* globals are intentionally not required here.

# Web frontend
WEB_APP_URL=https://www.example.com
WEB_REVALIDATE_SECRET=replace-me
# On a Linux VPS, point this to the public engine URL or a loopback-only reverse proxy target.
CONTENT_ENGINE_URL=https://aiblogs.earningsites.net
# Required: must match root .env INTERNAL_API_TOKEN
INTERNAL_API_TOKEN=

# AI providers
OPENAI_API_KEY=
OPENROUTER_API_KEY=
REPLICATE_API_TOKEN=
TEXT_MODEL_DRAFT=openrouter/cheap-model
TEXT_MODEL_QA=openrouter/better-model
IMAGE_MODEL=black-forest-labs/flux-schnell

# Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Budget controls
MONTHLY_BUDGET_USD=100
PUBLISH_QUOTA_MIN=4
PUBLISH_QUOTA_MAX=8
TOPIC_DISCOVERY_TARGET_PER_DAY=20
PIPELINE_MODE_DEFAULT=prepopulate_bulk_direct
BUDGET_MODE=normal
PREPOPULATE_BATCH_ID=
PREPOPULATE_TARGET_PUBLISHED=20
PREPOPULATE_BATCH_SIZE=3
PREPOPULATE_MAX_RUN_MINUTES=90
PREPOPULATE_MAX_COST_USD=15
# Worker batch sizes (per run)
ARTICLE_BATCH_SIZE=3
IMAGE_BATCH_SIZE=3
QA_BATCH_SIZE=100
PUBLISH_SCHEDULER_TICK_MINUTES=1
PUBLISH_REVALIDATE_ENABLED=true
PUBLISH_REVALIDATE_CONTINUE_ON_FAIL=true
PLAN_SCHEDULER_TICK_MINUTES=60
PLAN_SCHEDULER_MAX_RUNS_PER_TICK=2
PLAN_SCHEDULER_DAILY_CAP_BASE=1
PLAN_SCHEDULER_DAILY_CAP_STANDARD=2
PLAN_SCHEDULER_DAILY_CAP_PRO=4
PLAN_SCHEDULER_TEST_MODE=false
PLAN_TEST_INTERVAL_MINUTES_BASE=3
PLAN_TEST_INTERVAL_MINUTES_STANDARD=2
PLAN_TEST_INTERVAL_MINUTES_PRO=1
PLAN_TOPIC_REFILL_INTERVAL_MINUTES=15
PLAN_TOPIC_REFILL_COUNT=60
PLAN_AUTOMATION_TRIGGER_URL=https://n8n.earningsites.net/webhook/plan-automation
N8N_WORKFLOW_ID_ARTICLE_GENERATION=
N8N_WORKFLOW_ID_IMAGE_GENERATION=
N8N_WORKFLOW_ID_QA_PUBLISH=
