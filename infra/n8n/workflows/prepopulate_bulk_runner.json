    {
      "id": "loadCfg",
      "name": "Load Prepopulate Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        470,
        260
      ],
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForEachItem",
        "jsCode": "const root = (typeof $json === 'object' && $json) ? $json : {};\nconst input = (root.body && typeof root.body === 'object') ? root.body : root;\n\nconst targetPublishedCount = Math.max(1, Number(input.targetPublishedCount || input.prepopulateTargetPublishedCount || $env.PREPOPULATE_TARGET_PUBLISHED || 20));\nconst batchSize = Math.max(1, Number(input.batchSize || input.prepopulateBatchSize || $env.PREPOPULATE_BATCH_SIZE || 3));\nconst maxRunMinutes = Math.max(1, Number(input.maxRunMinutes || input.prepopulateMaxRunMinutes || $env.PREPOPULATE_MAX_RUN_MINUTES || 90));\nconst maxCostUsd = Math.max(1, Number(input.maxCostUsd || input.prepopulateMaxCostUsd || $env.PREPOPULATE_MAX_COST_USD || 15));\nconst siteSlug = String(input.siteSlug || $env.SITE_SLUG || 'hammer-hearth').toLowerCase().trim();\nconst pipelineMode = String(input.pipelineMode || 'prepopulate_bulk_direct');\nconst batchId = String(input.prepopulateBatchId || ('prepop-' + new Date().toISOString().replace(/[:.]/g, '-')));\n\nreturn {\n  json: {\n    targetPublishedCount,\n    batchSize,\n    maxRunMinutes,\n    maxCostUsd,\n    pipelineMode,\n    prepopulateBatchId: batchId,\n    siteSlug,\n  }\n};"
      }
    },
    {
      "id": "countPublished",
      "name": "Count published articles",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        760,
        260
      ],
      "parameters": {
        "method": "GET",
        "url": "={{ 'https://' + $env.SANITY_PROJECT_ID + '.api.sanity.io/v' + ($env.SANITY_API_VERSION || '2025-01-01') + '/data/query/' + ($env.SANITY_DATASET || 'production') + '?query=' + encodeURIComponent('count(*[_type==\\\"article\\\" && siteSlug==\\\"' + ($json.siteSlug || $env.SITE_SLUG || 'hammer-hearth') + '\\\" && status==\\\"published\\\"])') }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.SANITY_READ_TOKEN}}"
            }
          ]
        }
      }
    },
    {
      "id": "planCycles",
      "name": "Plan prepopulate cycles",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1050,
        260
      ],
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Load Prepopulate Config').item.json;\nconst countNode = $('Count published articles').item.json || {};\nconst publishedCount = Number(countNode.result || 0);\nconst remaining = Math.max(0, Number(cfg.targetPublishedCount || 0) - publishedCount);\nconst batchSize = Math.max(1, Number(cfg.batchSize || 3));\nconst plannedCycles = Math.ceil(remaining / batchSize);\n\nif (plannedCycles <= 0) {\n  return [{ json: { ...cfg, publishedCount, remaining, plannedCycles: 0, noWorkNeeded: true } }];\n}\n\nreturn Array.from({ length: plannedCycles }, (_, index) => ({\n  json: {\n    ...cfg,\n    publishedCount,\n    remaining,\n    plannedCycles,\n    cycleIndex: index + 1,\n    noWorkNeeded: false,\n  }\n}));"
      }
    },
    {
      "id": "noWorkGate",
      "name": "No work needed?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        1290,
        260
      ],
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{ Number($json.remaining || 0) }}",
              "operation": "smallerEqual",
              "value2": 0
            }
          ]
        },
        "options": {}
      }
    },
