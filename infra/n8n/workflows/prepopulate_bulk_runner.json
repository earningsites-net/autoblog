    {
      "id": "summary",
      "name": "Build Prepopulate Report",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2310,
        260
      ],
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const cfg = $('Load Prepopulate Config').item.json;\nconst allItems = (typeof $input !== 'undefined' && $input && typeof $input.all === 'function')\n  ? $input.all()\n  : (typeof items !== 'undefined' ? items : []);\nconst cycleItems = allItems.map((item) => item.json || {});\nconst executedCycles = cycleItems.filter((item) => !item.noWorkNeeded).length;\nconst plannedFromNode = Number(($('Plan prepopulate cycles').item.json || {}).plannedCycles || 0);\nconst plannedCycles = plannedFromNode || cycleItems.length || 0;\nreturn [{\n  json: {\n    workflowName: 'prepopulate_bulk_runner',\n    siteSlug: cfg.siteSlug,\n    batchId: cfg.prepopulateBatchId,\n    targetPublishedCount: cfg.targetPublishedCount,\n    batchSize: cfg.batchSize,\n    maxRunMinutes: cfg.maxRunMinutes,\n    maxCostUsd: cfg.maxCostUsd,\n    pipelineMode: cfg.pipelineMode,\n    plannedCycles,\n    executedCycles,\n    note: 'This runner orchestrates existing worker workflows. Configure N8N_WORKFLOW_ID_* env vars and keep PIPELINE_MODE_DEFAULT=prepopulate_bulk_direct during launch.'\n  }\n}];"
      }
    },
