NEXT_PUBLIC_DEFAULT_LOCALE=en-US
NEXT_PUBLIC_SITE_DESCRIPTION=
SITE_BLUEPRINT_PATH=./sites/hammer-hearth/site.blueprint.json
SITE_SLUG=hammer-hearth
SANITY_STUDIO_SITE_SLUG=hammer-hearth
NEXT_PUBLIC_SITE_SLUG=hammer-hearth

# Web / revalidate endpoint
REVALIDATE_SECRET=replace-me
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2025-01-01
SANITY_READ_TOKEN=
SANITY_WRITE_TOKEN=
SANITY_STUDIO_URL=http://localhost:3333
ENABLE_AD_SLOTS=false
CONTENT_REPOSITORY_DRIVER=auto
CONTENT_API_BASE_URL=
CONTENT_ENGINE_URL=http://localhost:8787
NEXT_PUBLIC_PORTAL_BASE_URL=http://localhost:8787
PREPOPULATE_TRIGGER_URL=http://localhost:5679/webhook/<workflow-id>/webhook%2520trigger/factory-prepopulate
GA_MEASUREMENT_ID=
GOOGLE_SITE_VERIFICATION=
PIPELINE_MODE_DEFAULT=prepopulate_bulk_direct
BUDGET_MODE=normal
PREPOPULATE_BATCH_ID=
PREPOPULATE_TARGET_PUBLISHED=30
PREPOPULATE_BATCH_SIZE=3
PREPOPULATE_MAX_RUN_MINUTES=90
PREPOPULATE_MAX_COST_USD=15
ARTICLE_BATCH_SIZE=3
IMAGE_BATCH_SIZE=3
QA_BATCH_SIZE=100
PUBLISH_SCHEDULER_TICK_MINUTES=1
PUBLISH_REVALIDATE_ENABLED=true
PUBLISH_REVALIDATE_CONTINUE_ON_FAIL=true
PLAN_AUTOMATION_TRIGGER_URL=http://localhost:5679/webhook/<workflow-id>/webhook%2520trigger/plan-automation
PLAN_SCHEDULER_TICK_MINUTES=60
PLAN_SCHEDULER_MAX_RUNS_PER_TICK=2
PLAN_SCHEDULER_DAILY_CAP_BASE=1
PLAN_SCHEDULER_DAILY_CAP_STANDARD=2
PLAN_SCHEDULER_DAILY_CAP_PRO=4
PLAN_SCHEDULER_TEST_MODE=false
PLAN_TEST_INTERVAL_MINUTES_BASE=3
PLAN_TEST_INTERVAL_MINUTES_STANDARD=2
PLAN_TEST_INTERVAL_MINUTES_PRO=1
PLAN_TOPIC_REFILL_INTERVAL_MINUTES=15
PLAN_TOPIC_REFILL_COUNT=60
# Required: shared with infra/n8n/.env
INTERNAL_API_TOKEN=
# Required: protects /api/factory/* and /v1/factory/*
FACTORY_API_SECRET=
# Optional: protects /ops/factory page with HTTP Basic Auth
# If FACTORY_UI_PASSWORD is empty, FACTORY_API_SECRET is used as password fallback.
FACTORY_UI_USERNAME=admin
FACTORY_UI_PASSWORD=
PLATFORM_ADSENSE_PUBLISHER_ID=

# n8n / AI providers (set in infra/n8n/.env separately for deploy)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
REPLICATE_API_TOKEN=
IMAGE_MODEL=black-forest-labs/flux-schnell
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Engine (future site factory)
ENGINE_PORT=8787
ENGINE_HOST=0.0.0.0
DEFAULT_WORKFLOW_RUNNER=direct
N8N_API_BASE_URL=
N8N_API_KEY=
PORTAL_DB_PATH=apps/engine/data/portal.db
PORTAL_SESSION_SECRET=replace-with-long-random
PORTAL_BASE_URL=http://localhost:8787
PORTAL_SINGLE_SITE_MODE=true
PORTAL_ADMIN_EMAIL=admin@example.com
PORTAL_ADMIN_PASSWORD=ChangeMe123!
PORTAL_OWNER_TEMP_PASSWORD=ChangeMe123!
# Password reset delivery:
# - auto (default): try Resend first, fallback to webhook
# - resend: use only Resend
# - webhook: use only webhook
PORTAL_PASSWORD_RESET_DELIVERY_MODE=auto
PORTAL_PASSWORD_RESET_TTL_MINUTES=30
PORTAL_PASSWORD_RESET_FROM="AutoBlog Portal <no-reply@updates.example.com>"
PORTAL_PASSWORD_RESET_REPLY_TO=support@example.com
RESEND_API_KEY=
PORTAL_PASSWORD_RESET_WEBHOOK_URL=
PORTAL_PASSWORD_RESET_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_BASE=
STRIPE_PRICE_ID_STANDARD=
STRIPE_PRICE_ID_PRO=
# Stripe proration behavior for plan changes:
# - always_invoice (recommended: immediate charge/refund of proration)
# - create_prorations (apply proration on next invoice)
# - none (no proration)
STRIPE_PRORATION_BEHAVIOR=always_invoice
